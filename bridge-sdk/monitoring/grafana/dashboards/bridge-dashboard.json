{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Bridge Transaction Volume & Throughput",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(bridge_transactions_processed_total[5m])",
          "legendFormat": "{{chain}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "ops"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Bridge End-to-End Latency (P50/P90/P99)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(bridge_transaction_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "P50 Latency",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum(rate(bridge_transaction_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "P90 Latency",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(bridge_transaction_latency_ms_bucket[5m])) by (le))",
          "legendFormat": "P99 Latency",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "ms"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "Circuit Breaker Active State",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "bridge_circuit_breaker_tripped",
          "legendFormat": "Tripped Flags",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 8
      },
      "id": 4,
      "title": "Queue Error/DLQ Rate",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "bridge_dlq_size_total",
          "legendFormat": "Failed Queue Items",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 25 }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "title": "Active Blockchain Listeners Sync Status",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "bridge_last_block_number",
          "legendFormat": "{{chain}} Last Block",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          }
        }
      }
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["bridge-sdk", "production"],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "BlackHole Bridge Monitoring Dashboard",
  "version": 1
}
