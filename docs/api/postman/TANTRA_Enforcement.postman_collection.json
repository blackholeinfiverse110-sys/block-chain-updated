{
  "info": {
    "name": "TANTRA Full Convergence — Blackhole Blockchain",
    "description": "Full PDV convergence collection. Start services first:\n  Terminal 1: cd core/relay-chain && go run cmd/fraud-service/main.go\n  Terminal 2: cd core/relay-chain && go run cmd/relay/main.go 3000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Successful Transaction (all hashes match)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "http://localhost:8080/api/relay/submit", "host": ["localhost"], "port": "8080", "path": ["api","relay","submit"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"schema_version\": \"v1\",\n  \"type\": \"token_transfer\",\n  \"from\": \"alice\",\n  \"to\": \"bob\",\n  \"amount\": 100,\n  \"token_id\": \"BHX\",\n  \"nonce\": 1,\n  \"timestamp\": {{$timestamp}}\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('success=true', () => pm.expect(b.success).to.be.true);",
            "pm.test('hashes match', () => {",
            "  pm.expect(b.execution_hash).to.equal(b.validation_hash);",
            "  pm.expect(b.validation_hash).to.equal(b.replay_hash);",
            "});",
            "pm.test('fraud=allow', () => pm.expect(b.fraud_decision).to.equal('allow'));",
            "pm.test('trace_id present', () => pm.expect(b.trace_id).to.be.a('string').with.lengthOf(16));",
            "pm.test('schema_version=v1', () => pm.expect(b.schema_version).to.equal('v1'));",
            "pm.environment.set('last_tx_id', b.transaction_id);",
            "pm.environment.set('last_trace_id', b.trace_id);"
          ]
        }
      }]
    },
    {
      "name": "2. Rejected — Fraud Block (bad-actor sender)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "http://localhost:8080/api/relay/submit", "host": ["localhost"], "port": "8080", "path": ["api","relay","submit"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"schema_version\": \"v1\",\n  \"type\": \"token_transfer\",\n  \"from\": \"bad-actor\",\n  \"to\": \"bob\",\n  \"amount\": 100,\n  \"token_id\": \"BHX\",\n  \"nonce\": 1,\n  \"timestamp\": {{$timestamp}}\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('HTTP 403', () => pm.response.to.have.status(403));",
            "const b = pm.response.json();",
            "pm.test('success=false', () => pm.expect(b.success).to.be.false);",
            "pm.test('error_code=PDV_REJECT', () => pm.expect(b.error_code).to.equal('PDV_REJECT'));",
            "pm.test('rejection_reason present', () => pm.expect(b.rejection_reason).to.be.a('string'));"
          ]
        }
      }]
    },
    {
      "name": "3. Rejected — Zero Amount (schema violation)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "http://localhost:8080/api/relay/submit", "host": ["localhost"], "port": "8080", "path": ["api","relay","submit"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"schema_version\": \"v1\",\n  \"type\": \"token_transfer\",\n  \"from\": \"alice\",\n  \"to\": \"bob\",\n  \"amount\": 0,\n  \"token_id\": \"BHX\",\n  \"nonce\": 2,\n  \"timestamp\": {{$timestamp}}\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('HTTP 400', () => pm.response.to.have.status(400));",
            "const b = pm.response.json();",
            "pm.test('success=false', () => pm.expect(b.success).to.be.false);",
            "pm.test('error_code=SCHEMA_VIOLATION', () => pm.expect(b.error_code).to.equal('SCHEMA_VIOLATION'));"
          ]
        }
      }]
    },
    {
      "name": "4. Rejected — Unknown Field (schema violation)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "http://localhost:8080/api/relay/submit", "host": ["localhost"], "port": "8080", "path": ["api","relay","submit"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"schema_version\": \"v1\",\n  \"type\": \"token_transfer\",\n  \"from\": \"alice\",\n  \"to\": \"bob\",\n  \"amount\": 100,\n  \"token_id\": \"BHX\",\n  \"nonce\": 1,\n  \"timestamp\": {{$timestamp}},\n  \"unknown_field\": \"this should be rejected\"\n}"
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('HTTP 400', () => pm.response.to.have.status(400));",
            "const b = pm.response.json();",
            "pm.test('SCHEMA_VIOLATION', () => pm.expect(b.error_code).to.equal('SCHEMA_VIOLATION'));"
          ]
        }
      }]
    },
    {
      "name": "5. Rejected — Missing schema_version",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
