# BlackHole Blockchain Ecosystem Configuration Template
# =======================================================
#
# Copy this file to .env and configure with your actual values
# cp .env.example .env
#
# This template includes configuration for all BlackHole components:
# - Blockchain Core (relay-chain)
# - Bridge SDK
# - Wallet Services
# - DEX
# - Smart Contracts
#

# ===== APPLICATION SETTINGS =====
APP_NAME=blackhole-ecosystem
APP_VERSION=1.0.0
APP_ENV=production

# ===== BLOCKCHAIN CORE CONFIGURATION =====
# Mainnet/Testnet mode
MAINNET_MODE=false
TESTNET_MODE=true
CHAIN_ID=testnet-001
NETWORK_ID=1337

# Node Configuration
NODE_ENV=production
DOCKER_MODE=true
LOG_LEVEL=info
BLOCKCHAIN_PORT=8080
RPC_PORT=8545
P2P_PORT=30303
DATABASE_PATH=./data/blockchain.db
LOG_FILE=./logs/blockchain.log

# Consensus Configuration
CONSENSUS_MODE=pos
VALIDATOR_STAKE_MINIMUM=1000000
BLOCK_TIME=3s
MAX_BLOCK_SIZE=1048576
EPOCH_LENGTH=1000

# P2P Networking
PEER_DISCOVERY=true
MAX_PEERS=50
BOOTSTRAP_NODES=localhost:30303,localhost:30304,localhost:30305
P2P_LISTEN_ADDR=0.0.0.0:30303

# ===== BRIDGE CONFIGURATION =====
# Bridge Application Settings
BRIDGE_APP_NAME=blackhole-bridge
BRIDGE_APP_VERSION=1.0.0
BRIDGE_APP_ENV=production

# Bridge Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8084
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s

# Bridge Database
BRIDGE_DB_PATH=./data/bridge.db
BRIDGE_DB_MAX_CONNECTIONS=10
BRIDGE_DB_CONNECTION_TIMEOUT=30s

# Blockchain RPC Endpoints (REQUIRED - Replace with your actual endpoints)
ETHEREUM_RPC_URL=https://eth-mainnet.alchemyapi.io/v2/YOUR_ALCHEMY_KEY_HERE
ETHEREUM_WS_URL=wss://eth-mainnet.alchemyapi.io/v2/YOUR_ALCHEMY_KEY_HERE
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
BLACKHOLE_RPC_URL=http://localhost:8545

# Testnet Configuration
ETHEREUM_TESTNET_RPC=https://eth-goerli.alchemyapi.io/v2/YOUR_ALCHEMY_KEY_HERE
SOLANA_TESTNET_RPC=https://api.devnet.solana.com
USE_TESTNET=true

# Bridge Contract Addresses (REQUIRED - Replace with actual contract addresses)
ETHEREUM_BRIDGE_CONTRACT=0x742d35Cc6634C0532925a3b8D4C9db96590c6C87
SOLANA_BRIDGE_PROGRAM=9WzDXwBbmkg8ZTbNMqUxvQRAyrZzDsGYdLVL9zYtAWWM
BLACKHOLE_BRIDGE_CONTRACT=bh1234567890123456789012345678901234567890

# Private Keys (CRITICAL - Replace with your actual private keys and keep secure!)
ETHEREUM_PRIVATE_KEY=your_ethereum_private_key_here
SOLANA_PRIVATE_KEY=your_solana_private_key_here
BLACKHOLE_PRIVATE_KEY=your_blackhole_private_key_here

# Security Configuration
JWT_SECRET=your_secure_jwt_secret_key_here_minimum_32_characters
API_KEY=your_secure_api_key_here
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Bridge Logging
BRIDGE_LOG_LEVEL=info
BRIDGE_LOG_FORMAT=json
BRIDGE_LOG_FILE=./logs/bridge.log
BRIDGE_LOG_MAX_SIZE=100MB
BRIDGE_LOG_MAX_BACKUPS=5
BRIDGE_LOG_MAX_AGE=30

# Bridge Monitoring
BRIDGE_METRICS_ENABLED=true
BRIDGE_METRICS_PORT=9090
BRIDGE_HEALTH_CHECK_INTERVAL=30s

# Bridge Settings
CONFIRMATION_BLOCKS_ETH=12
CONFIRMATION_BLOCKS_SOL=32
CONFIRMATION_BLOCKS_BH=6
MAX_RETRY_ATTEMPTS=3
RETRY_DELAY=5s
BATCH_SIZE=100

# Circuit Breaker
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60s
CIRCUIT_BREAKER_RESET_TIMEOUT=300s

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=300s
CACHE_MAX_SIZE=1000

# Replay Protection
REPLAY_PROTECTION_ENABLED=true
REPLAY_CACHE_SIZE=10000
REPLAY_CACHE_TTL=24h

# Recovery System
RECOVERY_ENABLED=true
RECOVERY_INTERVAL=60s
RECOVERY_MAX_ATTEMPTS=5
RECOVERY_BATCH_SIZE=50

# Gas Configuration
ETH_GAS_LIMIT=200000
ETH_GAS_PRICE=20000000000
SOL_COMPUTE_UNITS=200000
BH_GAS_LIMIT=100000

# Fee Configuration
BRIDGE_FEE_PERCENTAGE=0.1
MIN_BRIDGE_AMOUNT=0.001
MAX_BRIDGE_AMOUNT=1000

# ===== WALLET SERVICE CONFIGURATION =====
WALLET_PORT=8081
WALLET_DB_PATH=./data/wallet.db
WALLET_ENCRYPTION_KEY=your_wallet_encryption_key_here

# ===== DEX CONFIGURATION =====
DEX_ENABLED=true
DEX_PORT=8082
DEX_DB_PATH=./data/dex.db
DEX_FEE_RECIPIENT=your_fee_recipient_address_here

# ===== SMART CONTRACT CONFIGURATION =====
# Contract Deployment
PRIVATE_KEY=your_deployment_private_key_here
ETHERSCAN_API_KEY=your_etherscan_api_key_here
BSCSCAN_API_KEY=your_bscscan_api_key_here
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Network RPC URLs
ETHEREUM_MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/your-api-key
BSC_MAINNET_RPC=https://bsc-dataseed1.binance.org/
POLYGON_MAINNET_RPC=https://polygon-rpc.com/

# ===== MONITORING & LOGGING =====
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
ELK_STACK_ENABLED=false

# ===== BACKUP CONFIGURATION =====
BACKUP_ENABLED=true
BACKUP_INTERVAL=24h
BACKUP_RETENTION=7d
BACKUP_S3_BUCKET=blackhole-backups
BACKUP_ENCRYPTION_KEY=your_backup_encryption_key_here

# ===== NOTIFICATION SETTINGS =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM=alerts@blackhole.network
EMAIL_TO=admin@blackhole.network

# ===== DEVELOPMENT SETTINGS =====
DEBUG_MODE=false
ENABLE_PROFILING=false
ENABLE_TRACING=false

# ===== DOCKER COMPOSE SETTINGS =====
COMPOSE_PROJECT_NAME=blackhole-ecosystem
RESTART_POLICY=unless-stopped

# ===== VOLUME MOUNTS =====
BLOCKCHAIN_DATA_VOLUME=blockchain-data
BRIDGE_DATA_VOLUME=bridge-data
WALLET_DATA_VOLUME=wallet-data
LOGS_VOLUME=logs

# ===== NETWORK CONFIGURATION =====
NETWORK_NAME=blackhole-network
SUBNET=172.20.0.0/16

# ===== EXTERNAL SERVICES =====
REDIS_URL=redis://redis:6379
POSTGRES_URL=postgres://user:pass@postgres:5432/blackhole_db

# Production Security Notes:
# ==========================
# 1. Never commit .env files with real credentials to version control
# 2. Use environment-specific values for different deployments
# 3. Consider using Docker secrets or external secret management for production
# 4. Regularly rotate private keys and API keys
# 5. Use strong, unique passwords and secrets
# 6. Enable firewall rules to restrict access to sensitive ports
# 7. Use HTTPS in production with valid SSL certificates
# 8. Implement proper monitoring and alerting
# 9. Keep backups encrypted and secure
# 10. Test configuration thoroughly before production deployment