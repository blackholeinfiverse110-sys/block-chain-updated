# BlackHole Bridge Configuration (v0.3)
# Copy to .env and customize for your environment

# RPC Endpoints (mocks for development)
ETHEREUM_RPC=http://localhost:8545
SOLANA_RPC=http://localhost:8899
BLACKHOLE_RPC=http://localhost:8546

# Ports
HTTP_PORT=8080
GRPC_PORT=9090

# Database
DATABASE_PATH=bridge.db

# Retry Configuration
MAX_RETRIES=5
RETRY_DELAY_MS=1000  # Base delay for exponential backoff

# Features
CIRCUIT_BREAKER_ENABLED=true
REPLAY_PROTECTION_ENABLED=true
ENABLE_COLORED_LOGS=true

# Failure Injection (for testing, set to 0 in prod)
INJECT_DROP=0.03  # 3% drop rate
INJECT_DELAY_MS=50  # 50ms average delay

# Logging
LOG_LEVEL=info

# Batch and Queue
BATCH_SIZE=10
QUEUE_DEPTH_THRESHOLD=100  # Circuit breaker trigger

# Rate Limiting
RATE_LIMIT_PER_CHAIN=100  # Requests per minute per source chain

# Other
METRICS_SNAPSHOT_INTERVAL=30  # Seconds for metrics.json
DLQ_PATH=retry-dlq.jsonl

# Example usage: docker-compose up --env-file .env