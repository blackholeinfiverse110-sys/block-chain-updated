        "body": {
          "mode": "raw",
          "raw": "{\n  \"type\": \"token_transfer\",\n  \"from\": \"alice\",\n  \"to\": \"bob\",\n  \"amount\": 100,\n  \"token_id\": \"BHX\",\n  \"nonce\": 1,\n  \"timestamp\": {{$timestamp}}\n}"
