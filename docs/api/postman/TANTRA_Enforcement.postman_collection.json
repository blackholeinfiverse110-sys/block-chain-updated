    {
      "name": "6. Verify Transaction On-Chain (Bucket Phase 5)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/api/tantra/verify?tx_hash={{last_tx_id}}",
          "host": ["localhost"], "port": "8080",
          "path": ["api","tantra","verify"],
          "query": [{ "key": "tx_hash", "value": "{{last_tx_id}}" }]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('found on-chain', () => pm.expect(b.result.on_chain).to.be.true);",
            "pm.test('hashes_match', () => pm.expect(b.result.hashes_match).to.be.true);"
          ]
        }
      }]
    },
