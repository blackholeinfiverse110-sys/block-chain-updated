    {
      "name": "9. AKASHIC Trace Continuity (Phase 4)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/api/akashic/trace?trace_id={{last_trace_id}}",
          "host": ["localhost"], "port": "8080",
          "path": ["api","akashic","trace"],
          "query": [{ "key": "trace_id", "value": "{{last_trace_id}}" }]
        }
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
            "const b = pm.response.json();",
            "pm.test('entry found', () => pm.expect(b.success).to.be.true);",
            "pm.test('trace_id matches', () => pm.expect(b.entry.trace_id).to.equal(pm.environment.get('last_trace_id')));",
            "pm.test('PDV hashes equal in AKASHIC', () => {",
            "  pm.expect(b.entry.execution_hash).to.equal(b.entry.validation_hash);",
            "  pm.expect(b.entry.validation_hash).to.equal(b.entry.replay_hash);",
            "});"
          ]
        }
      }]
    },
